# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_TENANT_ID=your-tenant-id

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure Content Safety
CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=your-content-safety-key

# Azure Blob Storage
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;...
BLOB_CONTAINER_NAME=documents

# Azure Document Intelligence
DOC_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
DOC_INTELLIGENCE_KEY=your-doc-intelligence-key

# Azure AI Search
SEARCH_ENDPOINT=https://your-resource.search.windows.net
SEARCH_KEY=your-search-admin-key
SEARCH_INDEX_NAME=focusbuddy-documents

# Azure Web PubSub (Focus Room)
WEBPUBSUB_CONNECTION_STRING=Endpoint=https://your-resource.webpubsub.azure.com;AccessKey=...;Version=1.0;
WEBPUBSUB_HUB_NAME=focusroom

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=...

# CORS — Next.js frontend origin
FRONTEND_URL=http://localhost:3000
